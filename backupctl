#!/usr/bin/env python3
import os
import fcntl
import re
import stat
import sys
from pathlib import Path

HERE = Path(__file__).resolve().parent
release_helper_image = None
release_lease_fd = None
if not (HERE / 'homelab_backup').is_dir():
    install_root = HERE.parent / 'lib' / 'homelab-backup'
    releases_root = (install_root / 'releases').resolve()
    current_root = install_root / 'current'
    release_root = None
    pinned_release = os.environ.get('HOMELAB_BACKUP_RELEASE_ROOT')
    if pinned_release:
        candidate = Path(pinned_release).resolve()
        candidate_venv = candidate / 'venv'
        if Path(sys.prefix).resolve() == candidate_venv.resolve():
            release_root = candidate
    if release_root is None:
        try:
            release_root = current_root.resolve(strict=True)
        except OSError as err:
            raise SystemExit(
                f'ERROR: installed current release is invalid: {current_root}: {err}'
            ) from err
        os.environ['HOMELAB_BACKUP_RELEASE_ROOT'] = str(release_root)
    if (
        release_root.parent != releases_root
        or re.fullmatch(r'release\.[A-Za-z0-9]+', release_root.name) is None
        or not release_root.is_dir()
    ):
        raise SystemExit(
            f'ERROR: installed release is outside the release store: {release_root}'
        )
    lease_path = release_root / '.lease'
    try:
        release_lease_fd = os.open(
            lease_path, os.O_RDONLY | os.O_NOFOLLOW,
        )
        lease_metadata = os.fstat(release_lease_fd)
        allowed_owners = {0}
        if os.geteuid() != 0:
            allowed_owners.add(os.geteuid())
        if not stat.S_ISREG(lease_metadata.st_mode) \
                or lease_metadata.st_uid not in allowed_owners \
                or lease_metadata.st_mode & 0o022:
            raise OSError('lease is not a protected regular file')
        fcntl.flock(release_lease_fd, fcntl.LOCK_SH)
        os.set_inheritable(release_lease_fd, True)
    except OSError as err:
        if release_lease_fd is not None:
            os.close(release_lease_fd)
            release_lease_fd = None
        raise SystemExit(
            f'ERROR: installed release lease is invalid: {lease_path}: {err}'
        ) from err
    venv_root = release_root / 'venv'
    if Path(sys.prefix).resolve() != venv_root.resolve():
        venv_python = venv_root / 'bin' / 'python'
        if not venv_python.is_file() or not os.access(venv_python, os.X_OK):
            raise SystemExit(
                f'ERROR: installed Python environment is missing: {venv_python}'
            )
        os.execv(
            str(venv_python),
            [str(venv_python), str(Path(__file__).resolve()), *sys.argv[1:]],
        )
    app_root = release_root / 'app'
    if not (app_root / 'homelab_backup').is_dir():
        raise SystemExit(f'ERROR: installed application is missing: {app_root}')
    helper_image_file = release_root / 'volume-helper-image'
    try:
        release_helper_image = helper_image_file.read_text(encoding='utf-8').strip()
    except OSError as err:
        raise SystemExit(
            f'ERROR: installed helper image metadata is missing: {helper_image_file}: {err}'
        ) from err
    if re.fullmatch(r'homelab/volume-rsync:release\.[A-Za-z0-9]+', release_helper_image) is None:
        raise SystemExit(
            f'ERROR: installed helper image metadata is invalid: {helper_image_file}'
        )
    sys.path.insert(0, str(app_root))

if release_helper_image is not None:
    os.environ['HOMELAB_BACKUP_RELEASE_VOLUME_HELPER_IMAGE'] = release_helper_image

from homelab_backup.cli import main

if __name__ == '__main__':
    main()
